# Copy this file to .env and fill in real values.
# Get these from: Meta App Dashboard > Your App > Instagram >
#   "API setup with Instagram login" > 3. Set up Instagram business login

INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# Must exactly match a redirect URI registered in the App Dashboard
INSTAGRAM_REDIRECT_URI=http://localhost:5000/auth/callback

# Public URL of this app. Instagram must be able to reach
# BASE_URL/static/uploads/<file> to download your media.
# For local testing use a tunnel, e.g.: ngrok http 5000
# then set this to the https://xxxx.ngrok-free.app URL it gives you.
BASE_URL=http://localhost:5000

FLASK_SECRET_KEY=change-this-to-something-random
DATABASE_PATH=app.db
SCHEDULER_INTERVAL_SECONDS=60
